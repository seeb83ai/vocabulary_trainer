# Copy to .env and fill in your values.

# rsync destination for 'make release'
# Format: [user@]host:/path  or  just /local/path
# Example: pi@raspberrypi.local:/opt/vocab-trainer
RSYNC_DEST=pi@raspberrypi.local:/opt/vocab-trainer

# Port the server listens on (default: 8080)
PORT=8080

# Optional: protect the app with a single username/password.
# Leave both unset to disable authentication.
AUTH_USER=admin
AUTH_PASSWORD=changeme

# Optional: add a deepl.com API key to allow translations
DEEPL_API_KEY=
DEEPL_TARGET_LANGUAGE=en

# Optional: provide different audio files
# PINYIN_AUDIO_DIRS=/data/pinyin-audio:/data/alternative-audio

# set LLM keys to connect to AI model
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#GEMINI_API_KEY=
#LOCAL_LLM_URL=http://localhost:1234    # base URL of your local server
#LOCAL_LLM_MODEL=llama3.1               # model name as known to that server
#LOCAL_LLM_API_KEY=                     # optional bearer token (e.g. LM Studio)